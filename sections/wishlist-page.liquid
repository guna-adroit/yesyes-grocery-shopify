{% comment %}
  Wishlist Page Section
  Compatible with: Shopify Horizon Theme
  Requires: WishlistConfig global (set via snippet or theme.liquid)
{% endcomment %}

<link rel="stylesheet" href="{{ 'wishlist-page.css' | asset_url }}">

<div class="wishlist-page page-width" data-section-id="{{ section.id }}">

  <div class="wishlist-page__header">
    <h1 class="wishlist-page__title">
      {{ section.settings.title | default: 'My Wishlist' }}
      <wishlist-count class="wishlist-page__count-badge"></wishlist-count>
    </h1>
  </div>

  <div id="wishlist-page-state">

    {% comment %} Loading skeleton {% endcomment %}
    <div class="wishlist-loading" id="wishlist-loading" aria-live="polite" aria-label="Loading wishlist">
      <div class="wishlist-grid">
        {%- for i in (1..4) -%}
          <div class="wishlist-card wishlist-card--skeleton">
            <div class="wishlist-card__image skeleton-box"></div>
            <div class="wishlist-card__body">
              <div class="skeleton-box skeleton-box--title"></div>
              <div class="skeleton-box skeleton-box--price"></div>
              <div class="skeleton-box skeleton-box--btn"></div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    {% comment %} Empty state {% endcomment %}
    <div class="wishlist-empty hidden" id="wishlist-empty">
      <div class="wishlist-empty__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>
      </div>
      <h2 class="wishlist-empty__title">{{ section.settings.empty_title | default: 'Your wishlist is empty' }}</h2>
      <p class="wishlist-empty__subtitle">{{ section.settings.empty_subtitle | default: 'Save items you love and come back to them anytime.' }}</p>
      <a href="{{ section.settings.empty_cta_url | default: '/collections/all' }}" class="button button--primary wishlist-empty__cta">
        {{ section.settings.empty_cta_text | default: 'Start Shopping' }}
      </a>
    </div>

    {% comment %} Error state {% endcomment %}
    <div class="wishlist-error hidden" id="wishlist-error">
      <p>{{ section.settings.error_message | default: 'Something went wrong loading your wishlist. Please try again.' }}</p>
      <button class="button button--secondary" id="wishlist-retry-btn">Retry</button>
    </div>

    {% comment %} Product grid {% endcomment %}
    <div class="wishlist-results hidden" id="wishlist-results">
      <div class="wishlist-grid" id="wishlist-grid"></div>
      <div class="wishlist-pagination" id="wishlist-pagination"></div>
    </div>

  </div>

</div>

{% comment %} Product card template {% endcomment %}
<template id="wishlist-card-template">
  <div class="wishlist-card" data-product-id="">
    <div class="wishlist-card__image-wrap">
      <a class="wishlist-card__image-link" href="">
        <img class="wishlist-card__image" src="" alt="" loading="lazy" width="600" height="600">
      </a>
      <wishlist-button
        class="wishlist-card__remove"
        data-product-id=""
        data-product-title=""
        data-product-image="">
        <button
          type="button"
          data-wishlist-btn
          class="wishlist-btn active"
          aria-label="Remove from wishlist">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" />
          </svg>
        </button>
      </wishlist-button>
    </div>
    <div class="wishlist-card__body">
      <a class="wishlist-card__vendor" href=""></a>
      <a class="wishlist-card__title" href=""></a>
      <div class="wishlist-card__price">
        <span class="wishlist-card__price--current"></span>
        <s class="wishlist-card__price--compare hidden"></s>
      </div>
      <div class="wishlist-card__actions">
        <a class="button button--primary wishlist-card__cta" href="">View Product</a>
      </div>
    </div>
  </div>
</template>

<script>
  window.WishlistConfig = window.WishlistConfig || {};
  window.WishlistConfig.appProxyUrl   = {{ shop.url | append: '/apps/reviews' | json }};
  window.WishlistConfig.isLoggedIn    = {{ customer | json | default: 'null' }} !== null;
  window.WishlistConfig.customerId    = {{ customer.id | default: 0 | json }};
  window.WishlistConfig.pageLimit     = {{ section.settings.products_per_page | default: 12 }};
  window.WishlistConfig.moneyFormat   = {{ shop.money_format | json }};
</script>

<script src="{{ 'wishlist-page.js' | asset_url }}" defer></script>
{% comment %} <script src="{{ 'wishlist-button.js' | asset_url }}" defer></script> {% endcomment %}

{% schema %}
{
  "name": "Wishlist Page",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "My Wishlist"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 24,
      "step": 4,
      "label": "Products per page",
      "default": 12
    },
    {
      "type": "header",
      "content": "Empty State"
    },
    {
      "type": "text",
      "id": "empty_title",
      "label": "Empty state heading",
      "default": "Your wishlist is empty"
    },
    {
      "type": "text",
      "id": "empty_subtitle",
      "label": "Empty state subtext",
      "default": "Save items you love and come back to them anytime."
    },
    {
      "type": "url",
      "id": "empty_cta_url",
      "label": "Empty state button URL"
    },
    {
      "type": "text",
      "id": "empty_cta_text",
      "label": "Empty state button text",
      "default": "Start Shopping"
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "Error message",
      "default": "Something went wrong loading your wishlist. Please try again."
    },
    {
      "type": "header",
      "content": "Grid Layout"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4",
      "label": "Columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "2",
      "label": "Columns on mobile"
    }
  ],
  "presets": [
    {
      "name": "Wishlist Page"
    }
  ]
}
{% endschema %}
