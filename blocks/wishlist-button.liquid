<div class="wishlist-product-page" data-product-id="{{ product.id }}">
  <button 
    type="button" 
    class="wishlist-btn-product-page" 
    data-wishlist-btn
    data-product-id="{{ product.id }}"
  >
    <svg class="wishlist-icon-large" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path class="wishlist-icon-outline" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <path class="wishlist-icon-filled" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="currentColor" style="display: none;"/>
    </svg>
    <span class="wishlist-text">
      <span class="wishlist-text-add">{{ block.settings.add_text | default: 'Add to Wishlist' }}</span>
      <span class="wishlist-text-remove" style="display: none;">{{ block.settings.remove_text | default: 'Remove from Wishlist' }}</span>
    </span>
  </button>
</div>

<style>
  .wishlist-product-page {
    margin: {{ block.settings.margin_top | default: 20 }}px 0 {{ block.settings.margin_bottom | default: 20 }}px;
  }

  .wishlist-btn-product-page {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: {{ block.settings.button_background | default: 'transparent' }};
    border: {{ block.settings.button_border_width | default: 2 }}px solid {{ block.settings.button_border_color | default: '#000000' }};
    color: {{ block.settings.button_text_color | default: '#000000' }};
    padding: 12px 24px;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    border-radius: {{ block.settings.button_border_radius | default: 4 }}px;
    transition: all 0.3s ease;
    width: {{ block.settings.button_width | default: 'auto' }};
  }

  .wishlist-btn-product-page:hover {
    background: {{ block.settings.button_hover_background | default: '#f5f5f5' }};
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  }

  .wishlist-btn-product-page.active {
    background: {{ block.settings.active_button_background | default: '#ff0000' }};
    border-color: {{ block.settings.active_button_border_color | default: '#ff0000' }};
    color: {{ block.settings.active_button_text_color | default: '#ffffff' }};
  }

  .wishlist-icon-large {
    flex-shrink: 0;
  }

  .wishlist-btn-product-page.active .wishlist-icon-outline {
    display: none;
  }

  .wishlist-btn-product-page.active .wishlist-icon-filled {
    display: block !important;
  }

  .wishlist-btn-product-page.active .wishlist-text-add {
    display: none;
  }

  .wishlist-btn-product-page.active .wishlist-text-remove {
    display: inline !important;
  }

  @keyframes heartBeat {
    0%, 100% { transform: scale(1); }
    25% { transform: scale(1.2); }
    50% { transform: scale(1.1); }
  }

  .wishlist-btn-product-page.active .wishlist-icon-large {
    animation: heartBeat 0.3s ease;
  }

  .wishlist-toast {
  position: fixed;
  top: 20px;
  left: 0;
  background: #111;
  color: #fff;
  padding: 14px 16px;
  border-radius: 0 10px 10px 0;
  box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  z-index: 9999;
  max-width: 320px;

  /* Start hidden (off-screen left) */
  transform: translateX(-100%);
  opacity: 0;

  transition: transform 0.4s ease, opacity 0.4s ease;
}

/* Visible state */
.wishlist-toast.show {
  transform: translateX(0);
  opacity: 1;
}

/* Exit state */
.wishlist-toast.hide {
  transform: translateX(-100%);
  opacity: 0;
}

.wishlist-toast-inner {
  display: flex;
  align-items: center;
  gap: 12px;
}

.wishlist-toast img {
  width: 55px;
  height: 55px;
  object-fit: cover;
  border-radius: 6px;
}

.wishlist-toast-content strong {
  display: block;
  font-size: 14px;
  margin-bottom: 2px;
}

.wishlist-toast-content p {
  margin: 0;
  font-size: 13px;
  opacity: 0.85;
}
.wishlist-toast.removed {
  background: #2a0f0f;
  border-left: 4px solid #ff4d4d;
}
</style>

<script>
  (function() {
    const WISHLIST_STORAGE_KEY = 'shopify_wishlist';
    const APP_PROXY_URL = 'https://yesyes-grocerz.myshopify.com/apps/reviews'; // keep if using app proxy
    

    function initProductPageWishlist() {
      const button = document.querySelector('.wishlist-btn-product-page[data-wishlist-btn]');
      if (!button) return;

      const productId = button.getAttribute('data-product-id');

      if (isInWishlist(productId)) {
        button.classList.add('active');
      }
      if (isInWishlistServer(productId)) {
        button.classList.add('active');
      }

      button.addEventListener('click', handleWishlistToggle);
    }

    function isInWishlist(productId) {
      const wishlist = getWishlist();
      return wishlist.includes(productId);
    }
    function isInWishlistServer(productId) {
      const wishlist = getWishlistServer();
      return wishlist.includes(productId);
    }

    function getWishlist() {
      try {
        const wishlistData = localStorage.getItem(WISHLIST_STORAGE_KEY);
        return wishlistData ? JSON.parse(wishlistData) : [];
      } catch (e) {
        console.error('Error getting wishlist:', e);
        return [];
      }
    }

    async function getWishlistServer() {
      const wishlistButton = document.querySelector('.wishlist-btn-product-page[data-wishlist-btn]');
      try {
        const productIds = [
          {{product.id }}
        ];
        const response = await fetch("https://yesyes-grocerz.myshopify.com/apps/reviews/api/v1/wishlist/integration/verify", {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            customerId: "gid://shopify/Customer/23852944097361",
            productIds: productIds
                    })
                  });

            const data = await response.json();
            console.log(data);

            {% comment %} if (!response.ok || data.error) {
              // Revert UI on failure
              button.classList.toggle('active');
              throw new Error(data.error || 'Failed to get wishlist details');
            } {% endcomment %}

            

        return wishlistData ? JSON.parse(data) : [];
      } catch (e) {
        console.error('Error getting wishlist:', e);
        return [];
      }
    }

    function saveWishlistLocal(wishlist) {
      try {
        localStorage.setItem(WISHLIST_STORAGE_KEY, JSON.stringify(wishlist));
      } catch (e) {
        console.error('Error saving wishlist:', e);
      }
    }

    async function handleWishlistToggle(event) {
      event.preventDefault();

      const button = event.currentTarget;
      const productId = button.getAttribute('data-product-id');

      const isLoggedIn = {% if customer %}true{% else %}false{% endif %};

      if (isLoggedIn) {
        await toggleWishlistServer(productId, button);
      } else {
        toggleWishlistLocal(productId, button);
      }
    }

    function toggleWishlistLocal(productId, button) {
      const wishlist = getWishlist();
      const index = wishlist.indexOf(productId);

      const title = {{ product.title | json }};
      const image = {{ product.featured_image | image_url: width: 300 | json}};

      if (index > -1) {
        wishlist.splice(index, 1);
        button.classList.remove('active');
        showWishlistToast(title, image, 'removed');
      } else {
        wishlist.push(productId);
        button.classList.add('active');
        showWishlistToast(title, image, 'added');
      }

      saveWishlistLocal(wishlist);
      

      document.dispatchEvent(new CustomEvent('wishlist:updated', {
        detail: {
          wishlist,
          productId,
          action: index > -1 ? 'removed' : 'added'
        }
      }));
    }

    async function toggleWishlistServer(productId, button) {
      try {
        const customerId = "{{ customer.id }}";

        // Convert numeric IDs to GID format
        const productGid = `gid://shopify/Product/${productId}`;
        const customerGid = `gid://shopify/Customer/${customerId}`;

        // Optimistic UI update
        button.classList.toggle('active');

        const response = await fetch(`${APP_PROXY_URL}/api/v1/wishlist/integration/toggle`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            customerId: customerGid,
            productId: productGid
          })
        });

        const data = await response.json();
        console.log(data);

        if (!response.ok || data.error) {
          // Revert UI on failure
          button.classList.toggle('active');
          throw new Error(data.error || 'Failed to update wishlist');
        }

        // Update UI based on server response
        if (data.status === 'added') {
          button.classList.add('active');
        } else {
          button.classList.remove('active');
        }

        document.dispatchEvent(new CustomEvent('wishlist:updated', {
          detail: {
            productId,
            status: data.status
          }
        }));

      } catch (error) {
        console.error('Error updating wishlist:', error);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initProductPageWishlist);
    } else {
      initProductPageWishlist();
    }

    function showWishlistToast(title, image, type) {
        const existingToast = document.querySelector('.wishlist-toast');
        if (existingToast) existingToast.remove();

        const toast = document.createElement('div');
        toast.className = `wishlist-toast ${type}`;

        const message =
            type === 'added'
            ? 'has been added to Wishlist.'
            : 'has been removed from Wishlist.';

        toast.innerHTML = `
            <div class="wishlist-toast-inner">
            <img src="${image}" alt="${title}" />
            <div class="wishlist-toast-content">
                <strong>${title}</strong>
                <p>${message}</p>
            </div>
            </div>
        `;

        document.body.appendChild(toast);

        // Enter animation
        requestAnimationFrame(() => {
            toast.classList.add('show');
        });

        // Auto hide
        setTimeout(() => {
            toast.classList.remove('show');
            toast.classList.add('hide');

            setTimeout(() => {
            toast.remove();
            }, 400);
        }, 3000);
        }

  })();
</script>

{% schema %}
{
  "name": "Wishlist Button",
  "settings": [
    {
      "type": "text",
      "id": "add_text",
      "label": "Add to Wishlist Text",
      "default": "Add to Wishlist"
    },
    {
      "type": "text",
      "id": "remove_text",
      "label": "Remove from Wishlist Text",
      "default": "Remove from Wishlist"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button Background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button Hover Background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button Border Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Border Width",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 4
    },
    {
      "type": "color",
      "id": "active_button_background",
      "label": "Active Button Background",
      "default": "#ff0000"
    },
    {
      "type": "color",
      "id": "active_button_border_color",
      "label": "Active Button Border Color",
      "default": "#ff0000"
    },
    {
      "type": "color",
      "id": "active_button_text_color",
      "label": "Active Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "button_width",
      "label": "Button Width",
      "options": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "100%",
          "label": "Full Width"
        }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin Top (px)",
      "min": 0,
      "max": 50,
      "step": 5,
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin Bottom (px)",
      "min": 0,
      "max": 50,
      "step": 5,
      "default": 20
    }
  ],
  "presets": [
    {
        "name": "Wishlist button"
    }
  ]
}
{% endschema %}