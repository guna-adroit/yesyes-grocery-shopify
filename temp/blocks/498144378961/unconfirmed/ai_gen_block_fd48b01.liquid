    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Number",
      "default": "#0369a1"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#bae6fd"
    },
    {
      "type": "header",
      "content": "Low stock colors"
    },
    {
      "type": "color",
      "id": "low_stock_bg_color",
