{% comment %}
  snippet: wishlist-nav-icon.liquid
  Drop this snippet wherever you want a wishlist icon + live count badge in your header/nav.

  Usage:
    {% render 'wishlist-nav-icon' %}

  The <wishlist-count> web component is defined in wishlist-page.js.
  If wishlist-page.js is NOT loaded on every page, include wishlist-button.js instead,
  which also defines <wishlist-count>.
{% endcomment %}

<a
  href="/pages/wishlist"
  class="wishlist-nav-icon"
  aria-label="Wishlist">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    aria-hidden="true"
    class="wishlist-nav-icon__svg">
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
  </svg>
  <wishlist-count class="wishlist-nav-icon__badge"></wishlist-count>
</a>

<style>
  .wishlist-nav-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground, #111827);
    text-decoration: none;
  }

  .wishlist-nav-icon__svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .wishlist-nav-icon__badge {
    position: absolute;
    top: -0.4rem;
    right: -0.5rem;
    min-width: 1.1rem;
    height: 1.1rem;
    padding: 0 0.2rem;
    background: var(--color-wishlist-active, #ef4444);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .wishlist-nav-icon__badge[hidden] {
    display: none;
  }
</style>
