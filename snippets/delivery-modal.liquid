<style>
.radio-wrapper.date-selection {
    display: flex;
    gap: 16px;
    justify-content: space-between;
    flex-wrap: wrap;
}

.date-selection-wrapper,
.time-selection-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    background: #E0E0E0;
    border-radius: 4px;
    transition: 0.3s ease-in-out;
}
.time-selection-wrapper.disabled {
  opacity: 0.4;
  pointer-events: none;
}
.date-selection-wrapper {
    height: 50px;
    min-width: 75px;
    border: 1px solid #E0E0E0;
    flex-direction: column;
}

.date-selection-wrapper input,
.time-selection-wrapper input {
    display: none;
}

.date-selection-wrapper:has(input:checked),
.time-selection-wrapper:has(input:checked) {
    background: #ED1D23;
    border-color: #ED1D23;
    color: #fff;
}

.slot-label {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.day-label {
    font-weight: 700;
    font-size: 10px;
}

.date-label {
    font-weight: 600;
    font-size: 12px;
}

.timeslot-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
}

.time-selection-wrapper {
    flex: 0 0 calc(25% - 10px);
}

.time-selection-wrapper .slot-label {
    padding: 11px 18px;
}

.time-label {
    font-weight: 600;
    font-size: 12px;
}

/* Store Styles */
.store-container {
    display: flex;
    gap: 16px;
    padding: 15px;
    border: 1px solid #e1e1e1;
    border-radius: 6px;
}

.store-icon {
    width: 45px;
    height: 45px;
    background: #fee9e9;
    border-radius: 6px;
    display: flex;
    justify-content: center;
    align-items: center;
}

.store_name {
    font-weight: 700;
    font-size: 14px;
}

.store_address {
    font-weight: 500;
    font-size: 12px;
}

.selector-button {
    position: relative;
    display: flex;
    padding-top: 20px;
    padding-bottom: 25px;
    border: 1px solid #a3a3a3;
    border-radius: 6px;
    background: white;
    margin-top: 30px;
}

.selector-label {
    position: absolute;
    top: -25px;
    font-weight: 600;
    font-size: 14px;
    line-height: 19.6px;
    letter-spacing: 0;
}

span.selector-text {
    margin-left: 27px;
    font-weight: 400;
    font-size: 16px;
    line-height: 21.4px;
    letter-spacing: 0;
    color: #7F7C7C;
}
.selector-button::after {
    content: '';
    position: absolute;
    right: 20px;
    top: 45%;
    transform: translateY(-50%) rotate(45deg);
    border: 2px solid #000;
    width: 7px;
    height: 7px;
    border-width: 0px 2px 2px 0;
    transition: transform 0.3s ease;
}
.selector-button.active::after{
    transform: translateY(-50%) rotate(-135deg);
}
.check-icon {
    min-width: 18px;
    min-height: 14px;
    margin-left: auto;
}
.check-icon svg path{
    fill: rgb(180, 180, 180);
}
.store-container:has(input:checked) .check-icon svg path {
    fill: #ED1D23;
}
.store-container input[type="radio"] {
    height: 0;
    width: 0;
    opacity: 0;
}
/* Basic modal styling */
.modal {
    display: none;
    margin-top: 15px;
}
.modal.active {
    display: block;
}
@media (max-width: 750px) {
    .time-selection-wrapper {
        flex: 0 0 calc(34% - 10px);
    }
    .date-selection-wrapper {
        flex: 0 0 calc(33% - 10px);
    }
}   
</style>

    <button id="store-selector-button" class="selector-button">
        <div class="selector-label">Select a store</div>
    <span class="selector-text">Select a store</span>
    </button>
    
    <!-- Pickup details -->
    <div id="store-details-modal" class="modal">
        <div class="store-selector-wrapper">
            {% for shop in metaobjects.store_location.values %}
                <div class="store-container">
                <input 
                    type="radio"
                    id="store-{{ forloop.index }}"
                    name="pickup-store"
                    value="{{ shop.store_name }} | {{ shop.store_address }}"
                    class="store-option"
                >
                <label for="store-{{ forloop.index }}" style="display:flex; gap:16px; cursor:pointer; width:100%;">
                    <div class="store-icon">
                    {% render 'house-icon' %}
                    </div>
                    <div>
                        <div class="store_name">{{ shop.store_name }}</div>
                        <div class="store_address">{{ shop.store_address }}</div>
                    </div>
                    <div class="check-icon">
                        {% render 'check-icon' %}
                    </div>
                </label>
                </div>
            {% endfor %}
        </div>
    </div>

    <button id="slot-selector-button" class="selector-button">
        <div class="selector-label">Select a time slot</div>
    <span class="selector-text">Select time slot</span>
    </button>

    <!-- Pickup details -->
    <div id="time-slot-modal" class="modal">
        <div>
            {% comment %} 4 Radio buttons {% endcomment %}
            {% assign slot_2 = "now" | date: "%s" | plus: 86400 %}
            {% assign slot_2 = slot_2 | date: "%d-%m-%Y" %}
            {% assign slot_3 = "now" | date: "%s" | plus: 172800 %}
            {% assign slot_3 = slot_3 | date: "%d-%m-%Y" %}
            {% assign slot_4 = "now" | date: "%s" | plus: 259200 %}
            {% assign slot_4 = slot_4 | date: "%d-%m-%Y" %}
            {% assign slot_5 = "now" | date: "%s" | plus: 345600 %}
            {% assign slot_5 = slot_5 | date: "%d-%m-%Y" %}
            {% assign slot_6 = "now" | date: "%s" | plus: 432000 %}
            {% assign slot_6 = slot_6 | date: "%d-%m-%Y" %}
            <div class="radio-wrapper date-selection">
                <div class="date-selection-wrapper">
                    <input 
                        type="radio" 
                        id="{{ "now" | date: "%d-%m-%Y" }}" 
                        name="pickup-date" 
                        value="{{ "now" | date: "%d-%m-%Y" }}"
                        class="date-option"
                    >
                    <label class="slot-label" for="{{ "now" | date: "%d-%m-%Y" }}">
                        <span class="day-label">Today</span>
                        <span class="date-label">{{ "now" | date: "%b %d" }}</span>
                    </label>
                
                </div>
                <div class="date-selection-wrapper">
                    <input 
                        type="radio" 
                        id="{{ slot_2 }}" 
                        name="pickup-date" 
                        value="{{ slot_2 }}"
                        class="date-option"
                    >
                    <label class="slot-label" for="{{ slot_2 }}">
                        <span class="day-label">Tomorrow</span>
                        <span class="date-label">{{ slot_2 | date: "%b %d" }}</span>
                    </label>
                </div>
                <div class="date-selection-wrapper">
                    <input 
                        type="radio" 
                        id="{{ slot_3 }}" 
                        name="pickup-date" 
                        value="{{ slot_3 }}"
                        class="date-option"
                    >
                    
                    <label class="slot-label" for="{{ slot_3 }}">
                        <span class="day-label">{{ slot_3 | date: "%A" }}</span>
                        <span class="date-label">{{ slot_3 | date: "%b %d" }}</span>
                    </label>
                </div>
                <div class="date-selection-wrapper">
                    <input 
                        type="radio" 
                        id="{{ slot_4 }}" 
                        name="pickup-date" 
                        value="{{ slot_4 }}"
                        class="date-option"
                    >
                    <label class="slot-label" for="{{ slot_4 }}">
                        <span class="day-label">{{ slot_4 | date: "%A" }}</span>
                        <span class="date-label">{{ slot_4 | date: "%b %d" }}</span>
                    </label>
                </div>
                <div class="date-selection-wrapper">
                    <input 
                        type="radio" 
                        id="{{ slot_5 }}" 
                        name="pickup-date" 
                        value="{{ slot_5 }}"
                        class="date-option"
                    >
                    <label class="slot-label" for="{{ slot_5 }}">
                        <span class="day-label">{{ slot_5 | date: "%A" }}</span>
                        <span class="date-label">{{ slot_5 | date: "%b %d" }}</span>
                    </label>
                </div>
                <div class="date-selection-wrapper">
                    <input 
                        type="radio" 
                        id="{{ slot_6 }}" 
                        name="pickup-date" 
                        value="{{ slot_6 }}"
                        class="date-option"
                    >
                    <label class="slot-label" for="{{ slot_6 }}">
                        <span class="day-label">{{ slot_6 | date: "%A" }}</span>
                        <span class="date-label">{{ slot_6 | date: "%b %d" }}</span>
                    </label>
                </div>
            </div>
        </div>

        <div class="timeslot-wrapper">
            {% for slot in metaobjects.pickup_slots.values %}
                <div class="time-selection-wrapper">
                    <input 
                        type="radio" 
                        id="{{ slot.slot_label }}" 
                        name="pickup-time" 
                        value="{{ slot.slot_label }}"
                        class="time-option"
                        data-start="{{ slot.start_time }}"
                        data-end="{{ slot.end_time }}"
                    >
                    <label class="slot-label" for="{{ slot.slot_label }}">
                        <span class="time-label">{{ slot.slot_label }}</span>
                    </label>
                </div>
            {% endfor %}
        </div>

    </div>


<script>
document.addEventListener('DOMContentLoaded', function () {

  const checkoutBtn = document.getElementById('checkout');
  const warningButton = document.getElementById('warning-button');
  const storeBtn = document.getElementById('store-selector-button');
  const slotBtn = document.getElementById('slot-selector-button');
  const pickupModal = document.getElementById('store-details-modal');
  const slotModal = document.getElementById('time-slot-modal');
  const deliveryOptions = document.querySelectorAll('.delivery-option');
  const PICKUP_BUFFER_HOURS = 1; // Change anytime


  function parseDateDMY(dateStr) {
  const [day, month, year] = dateStr.split('-').map(Number);
  return new Date(year, month - 1, day);
}

function parseTimeToDate(baseDate, timeStr) {
  const [hours, minutes] = timeStr.split(':').map(Number);
  const date = new Date(baseDate);
  date.setHours(hours, minutes, 0, 0);
  return date;
}

function updateTimeSlotAvailability() {

  const selectedDateStr = state.date;
  if (!selectedDateStr) return;

  const now = new Date();
  const bufferTime = new Date(now.getTime() + PICKUP_BUFFER_HOURS * 60 * 60 * 1000);
  console.log('Buffer Time:', bufferTime);
  const selectedDate = parseDateDMY(selectedDateStr);

  document.querySelectorAll('input[name="pickup-time"]').forEach(radio => {

    const startTimeStr = radio.dataset.start;
    if (!startTimeStr) return;

    const slotStart = parseTimeToDate(selectedDate, startTimeStr);

    let disabled = false;

    // If selected date is today
    const isToday =
      selectedDate.toDateString() === now.toDateString();

    if (isToday) {
      if (slotStart <= bufferTime) {
        disabled = true;
      }
    }

    radio.disabled = disabled;

    if (disabled) {
      radio.closest('.time-selection-wrapper').classList.add('disabled');
      if (radio.checked) {
        radio.checked = false;
        state.time = null;
        slotBtn.querySelector('.selector-text').textContent = 'Select time slot';
      }
    } else {
      radio.closest('.time-selection-wrapper').classList.remove('disabled');
    }
  });

  updateCheckoutState();
}
document.querySelectorAll('input[name="pickup-date"]').forEach(radio => {
  radio.addEventListener('change', function () {
    state.date = this.value;
    state.time = null;

    document.querySelectorAll('input[name="pickup-time"]').forEach(r => r.checked = false);

    slotBtn.querySelector('.selector-text').textContent = 'Select time slot';

    updateTimeSlotAvailability(); // 🔥 ADD THIS

    updateCheckoutState();
  });
});


  let state = {
    pickup: false,
    store: null,
    date: null,
    time: null
  };

  /* -----------------------
     Force Default Delivery
  ----------------------- */
  const onlineOption = document.querySelector('.delivery-option[value="delivery"]');
  if (onlineOption) {
    onlineOption.checked = true;
  }

  /* -----------------------
     Toggle UI
  ----------------------- */
    function updateDeliveryUI() {
        if (state.pickup) {
            storeBtn.classList.remove('hidden');
            slotBtn.classList.remove('hidden');
        } else {
            storeBtn.classList.add('hidden');
            slotBtn.classList.add('hidden');
            resetPickupSelections();
        }
    }


  function resetPickupSelections() {
    state.store = null;
    state.date = null;
    state.time = null;

    document.querySelectorAll('input[name="pickup-store"]').forEach(r => r.checked = false);
    document.querySelectorAll('input[name="pickup-date"]').forEach(r => r.checked = false);
    document.querySelectorAll('input[name="pickup-time"]').forEach(r => r.checked = false);

    storeBtn.querySelector('.selector-text').textContent = 'Select a store';
    slotBtn.querySelector('.selector-text').textContent = 'Select time slot';

    updateCheckoutState();
  }

  deliveryOptions.forEach(option => {
    option.addEventListener('change', function () {
      state.pickup = this.value === 'pickup';
      updateDeliveryUI();
      updateCheckoutState();
    });
  });

  /* -----------------------
     Enable / Disable Checkout
  ----------------------- */
    function updateCheckoutState() {
        if (!state.pickup) {
            checkoutBtn.disabled = false;
            checkoutBtn.classList.remove('hidden');
            warningButton.classList.add('hidden');
            return;
        }

        const valid = state.store && state.date && state.time;

        checkoutBtn.disabled = !valid;
        if (valid) {
        checkoutBtn.classList.remove('hidden');
        warningButton.classList.add('hidden');
        } else {
        checkoutBtn.classList.add('hidden');
        warningButton.classList.remove('hidden');
        }
    }
    /* -----------------------
    Dropdown Behaviour
    ----------------------- */

    function toggleModal(modal, button) {
        const isActive = modal.classList.contains('active');

        // Close everything first
        closeAll();

        // If it was NOT active before, open it
        if (!isActive) {
            modal.classList.add('active');
            button.classList.add('active');
        }
    }

    function closeAll() {
        pickupModal.classList.remove('active');
        slotModal.classList.remove('active');
        storeBtn.classList.remove('active');
        slotBtn.classList.remove('active');
    }

    storeBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleModal(pickupModal, storeBtn);
    });

    slotBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleModal(slotModal, slotBtn);
    });

    document.addEventListener('click', function (e) {
    if (
        !pickupModal.contains(e.target) &&
        !slotModal.contains(e.target) &&
        !storeBtn.contains(e.target) &&
        !slotBtn.contains(e.target)
    ) {
        closeAll();
    }
    });

  /* -----------------------
     Store Selection
  ----------------------- */
  document.querySelectorAll('input[name="pickup-store"]').forEach(radio => {
    radio.addEventListener('change', function () {
      state.store = this.value;

      storeBtn.querySelector('.selector-text').textContent =
        this.value.split('|')[0].trim();

      closeAll();
      updateCheckoutState();
    });
  });

  /* -----------------------
     Date Selection
  ----------------------- */
  document.querySelectorAll('input[name="pickup-date"]').forEach(radio => {
    radio.addEventListener('change', function () {
      state.date = this.value;
      state.time = null;

      // clear previously selected time
      document.querySelectorAll('input[name="pickup-time"]').forEach(r => r.checked = false);

      slotBtn.querySelector('.selector-text').textContent = 'Select time slot';

      updateCheckoutState();
    });
  });

  /* -----------------------
     Time Selection (Auto Close)
  ----------------------- */
  document.querySelectorAll('input[name="pickup-time"]').forEach(radio => {
    radio.addEventListener('change', function () {

      if (!state.date) {
        alert('Please select a date first.');
        this.checked = false;
        return;
      }

      state.time = this.value;

      slotBtn.querySelector('.selector-text').textContent =
        `${state.date} | ${state.time}`;

      closeAll();
      updateCheckoutState();
    });
  });

  /* -----------------------
     Checkout Save Note
  ----------------------- */
  checkoutBtn.addEventListener('click', function (e) {

    if (!state.pickup) return;

    if (!state.store || !state.date || !state.time) {
      e.preventDefault();
      alert('Please complete pickup selection.');
      return;
    }

    e.preventDefault();

    const note = `
Store Pickup:
Store: ${state.store}
Date: ${state.date}
Time: ${state.time}
    `.trim();

    fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ note })
    }).then(() => {
      window.location.href = '/checkout';
    });
  });

  /* -----------------------
     Initial UI Setup
  ----------------------- */
  updateDeliveryUI();
  updateCheckoutState();
  if (state.date) {
    updateTimeSlotAvailability();
 }

});
</script>

